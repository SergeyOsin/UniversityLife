экспертиза :-
    консультация("Собака"),
    clear.

консультация(X) :-
    работа(X), !.

консультация(_) :-
    nl, write("Не удалось определить"), nl.

% --- ЛОГИКА ---
работа(X) :-
    \+ rule(_, X, _, _),
    nl, write("Результат: "), write(X), nl.

работа(X) :-
    rule(_, X, Y, Conds),
    проверка(Conds),
    работа(Y).

% --- ПРОВЕРКА УСЛОВИЙ ---
проверка([]).

проверка([H|T]) :-
    yes(H), !,
    проверка(T).

проверка([H|_]) :-
    no(H), !,
    fail.

проверка([H|T]) :-
    cond(H, Text),
    спросить(H, Text),
    проверка([H|T]).

спросить(N, Text) :-
    write("Вопрос: "), write(Text), write("? (y/n) "),
    read(Resp),
    сохранить(N, Resp).

сохранить(N, y) :- assertz(yes(N)).
сохранить(N, n) :- assertz(no(N)), fail.

clear :-
    retract(yes(_)), fail.
clear :-
    retract(no(_)), fail.
clear.
